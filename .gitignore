# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Stray nested git repo (see README/notes) ───────────────────────────────
# A leftover .git exists inside bookstaber_abm/ — it must be removed (not just
# ignored) before `git init` at the root, or the package becomes an embedded repo.
bookstaber_abm/.git/

# ── Editor / OS ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Internal notes / scratch (not for publication) ──────────────────────────
.claude/
claude plans/
CLAUDE.md
# Unrelated scratch output that landed in the repo root (not part of this project)
op llama local.md

# ── Generated run artifacts (regenerated by the experiment scripts) ─────────
# Keep the outputs/ directory, ignore its generated contents.
outputs/*
!outputs/.gitkeep

# NOTE: paper/figures/ is intentionally NOT ignored — those PNGs and table
# fragments are referenced by paper/paper.md and ship with the manuscript.
